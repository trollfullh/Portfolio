<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Student Portfolio</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Segoe UI,sans-serif;
}

body{
background:#f5f5f5;
padding:30px;
}

.container{
max-width:1400px;
margin:auto;
}

.header{
margin-bottom:20px;
}

.logo{
font-size:48px;
color:#9b6bc4;
}

.title{
font-size:48px;
font-weight:bold;
margin-top:10px;
}

.main{
display:grid;
grid-template-columns:320px 1fr;
gap:25px;
}

.sidebar{
background:white;
padding:20px;
border-radius:10px;
}

.sidebar h3{
margin-bottom:20px;
color:#8d68b2;
}

.menu-item{
padding:12px;
cursor:pointer;
border-radius:8px;
margin-bottom:8px;
transition:0.3s;
}

.menu-item:hover{
background:#f0e8f7;
}

.content{
display:flex;
flex-direction:column;
gap:20px;
}

.about{
background:#f3edf8;
padding:20px;
border-radius:10px;
}

.about h2{
color:#8d68b2;
margin-bottom:15px;
}

.info{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:20px;
}

.card{
background:white;
padding:20px;
border-radius:10px;
border:1px solid #ddd;
}

.card-title{
font-weight:bold;
color:#8d68b2;
margin-bottom:10px;
}

.section-title{
font-size:24px;
font-weight:bold;
margin:15px 0;
}

.gallery{
display:grid;
grid-template-columns:repeat(2,1fr);
gap:20px;
}

.gallery img{
width:100%;
height:300px;
object-fit:cover;
border-radius:10px;
border:1px solid #ddd;
}

.video-box{
width:100%;
aspect-ratio:16/9;
}

.video-box iframe{
width:100%;
height:100%;
border:none;
border-radius:10px;
}

.hidden{
display:none;
}

@media(max-width:900px){

.main{
grid-template-columns:1fr;
}

.info{
grid-template-columns:1fr;
}

.gallery{
grid-template-columns:1fr;
}

}

</style>
</head>

<body>

<div class="container">

<div class="header">

<div class="logo">🎓</div>

<div class="title">
Student Portfolio
</div>

</div>

<div class="main">

<div class="sidebar">

<h3>Tên các bài học</h3>

<div class="menu-item" onclick="showSection('bai1')">
